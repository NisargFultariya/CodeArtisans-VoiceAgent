# LiveKit worker — WebSocket connection to LiveKit Cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=avip-recovery-agent

# Voice AI
SARVAM_API_KEY=
SARVAM_TTS_SPEAKER=priya
OPENROUTER_API_KEY=
# Browser demo scenario replies (after predetermined greeting + question)
OPENROUTER_DEMO_MODEL=openai/gpt-4o-mini
DEFAULT_LANGUAGE=hi-IN

# Platform backend (HTTP signals only — no direct DB/Temporal access)
AVIP_API_URL=http://localhost:3000
AVIP_INTERNAL_SIGNAL_SECRET=dev-internal-secret-change-me
