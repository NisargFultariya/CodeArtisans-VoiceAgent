# Copy to .env.staging-demo on the staging EC2 (platform repo root).
# Public URL users open in the browser — must match Caddy host (HTTPS).
APP_URL=https://3-111-61-150.sslip.io

POSTGRES_PASSWORD=change-me-staging-demo-db

# LiveKit — same cloud project as the Python agent worker
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_URL=https://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=avip-recovery-agent

# Voice (browser demo STT/TTS)
SARVAM_API_KEY=
SARVAM_TTS_SPEAKER=priya

# Demo dialogue closings (OpenRouter)
OPENROUTER_API_KEY=

# Secrets — generate fresh for staging; do not reuse dev defaults
AVIP_INTERNAL_SIGNAL_SECRET=
AVIP_ADMIN_SESSION_SECRET=
AVIP_VOICE_DEMO_TOKEN_SECRET=

# Demo gate — keep true for invite-only testers; false only for quick internal video shoots
AVIP_VOICE_DEMO_GATE_ENABLED=true

# Admin (send demo magic links from /admin after login)
AVIP_ADMIN_USERNAME=admin
AVIP_ADMIN_PASSWORD=change-me

# Outbound email for demo invites (required when gate enabled)
# Use SES, SendGrid, or Mailgun — not Mailpit on staging.
SMTP_HOST=
SMTP_PORT=587
AVIP_MAIL_ENABLED=true
AVIP_MAIL_FROM=Soniqa Demo <noreply@yourdomain.com>

# Optional — demo-only stack does not run Temporal/worker/MinIO
SIMULATION_MODE_ENABLED=false
