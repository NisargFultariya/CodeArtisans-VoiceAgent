# Copy to .env in this repo root (platform/)

# PostgreSQL — overridden in compose for containers; host JDBC uses localhost:5433
DATABASE_URL=jdbc:postgresql://localhost:5433/avip
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=avip-main

# API
PORT=3000
APP_URL=http://localhost:3000
AVIP_INTERNAL_SIGNAL_SECRET=dev-internal-secret-change-me
AVIP_ADMIN_USERNAME=admin
AVIP_ADMIN_PASSWORD=admin
AVIP_ADMIN_SESSION_SECRET=dev-admin-session-secret-change-me
AVIP_ADMIN_SESSION_TTL_HOURS=24
SIMULATION_MODE_ENABLED=true
AVIP_DEV_STORE=avip-store-ioj9xku3.myshopify.com
DEFAULT_LANGUAGE=hi-IN

# LiveKit — platform server SDK (room create, dispatch, SIP)
# Keys are often maintained in ../avip/.env; compose loads that file as a fallback.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_URL=https://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=avip-recovery-agent
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# Browser demo STT/TTS
SARVAM_API_KEY=
# bulbul:v3 speaker — female default for Soniqa (e.g. priya, ishita, ritu)
SARVAM_TTS_SPEAKER=priya

# Demo transcript logging (Postgres + files under transcript-log-dir)
AVIP_DEMO_TRANSCRIPT_LOG_ENABLED=true
AVIP_DEMO_TRANSCRIPT_LOG_DIR=data/demo-transcripts

# Outbound email (Mailpit locally — UI http://localhost:8025)
SMTP_HOST=localhost
SMTP_PORT=1025
AVIP_MAIL_ENABLED=true
AVIP_MAIL_FROM=AVIP <noreply@avip.local>

# Object storage (recordings) — compose service minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=avip-recordings
MINIO_REGION=us-east-1

# Shopify Admin API (optional until webhooks are wired)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2024-10
TOKEN_ENCRYPTION_KEY=
